#!/usr/bin/env bash

set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$HERE/env" "$@"

cd "$DIR"

validate_bundler_supply_chain() {
  ruby -rbundler -ryaml - "$DIR" <<'RUBY'
root = ARGV.fetch(0)
failures = []

config = YAML.safe_load_file(
  File.join(root, ".bundle/config"),
  permitted_classes: [],
  permitted_symbols: [],
  aliases: false
)
required_config = {
  "BUNDLE_FROZEN" => "true",
  "BUNDLE_PATH" => "vendor/gems",
  "BUNDLE_CACHE_PATH" => "vendor/cache",
  "BUNDLE_NO_INSTALL" => "true"
}
required_config.each do |key, value|
  failures << ".bundle/config must set #{key}: #{value.inspect}" unless config[key] == value
end

lock_path = File.join(root, "Gemfile.lock")
lock_text = File.read(lock_path)
unless lock_text.match?(/\ACHECKSUMS\n|\nCHECKSUMS\n/)
  failures << "Gemfile.lock is missing CHECKSUMS"
end

checksum_entries = {}
in_checksums = false
lock_text.each_line do |line|
  stripped = line.chomp
  if stripped == "CHECKSUMS"
    in_checksums = true
    next
  end
  next unless in_checksums
  break if stripped.match?(/\A[A-Z][A-Z ]*\z/)
  next if stripped.empty?

  match = stripped.match(/\A  (?<name>.+) \((?<version>[^)]+)\) sha256=(?<sha>[0-9a-f]{64})\z/)
  if match
    checksum_entries[[match[:name], match[:version]]] = match[:sha]
  else
    failures << "invalid Gemfile.lock checksum line: #{stripped}"
  end
end

specs = Bundler::LockfileParser.new(lock_text).specs
specs.each do |spec|
  platform = spec.platform.to_s
  checksum_version = platform == "ruby" ? spec.version.to_s : "#{spec.version}-#{platform}"
  next if checksum_entries.key?([spec.name, checksum_version])

  failures << "missing checksum for #{spec.name} (#{checksum_version})"
end

cache_dir = File.join(root, "vendor/cache")
expected_cache = specs.map { |spec| "#{spec.full_name}.gem" }.sort
actual_cache = Dir.exist?(cache_dir) ? Dir.children(cache_dir).grep(/\.gem\z/).sort : []
missing_cache = expected_cache - actual_cache
extra_cache = actual_cache - expected_cache

missing_cache.each { |gem| failures << "missing cached gem: vendor/cache/#{gem}" }
extra_cache.each { |gem| failures << "extra cached gem: vendor/cache/#{gem}" }

unless failures.empty?
  warn failures.join("\n")
  exit 1
end
RUBY
}

validate_ci_workflow_security() {
  ruby -ryaml - "$DIR" <<'RUBY'
root = ARGV.fetch(0)
failures = []
sealed_workflows = %w[build.yml lint.yml test.yml]
workflow_paths = Dir[File.join(root, ".github/workflows/*.{yml,yaml}")].sort

workflow_paths.each do |path|
  relative = path.delete_prefix("#{root}/")
  workflow_name = File.basename(path)
  workflow = YAML.safe_load(File.read(path), permitted_classes: [], permitted_symbols: [], aliases: false)
  jobs = workflow.fetch("jobs", {})

  File.readlines(path).each_with_index do |line, index|
    match = line.match(/\buses:\s*['"]?(?<uses>[^'"\s#]+)['"]?/)
    next unless match

    value = match[:uses]
    next if value.start_with?("./")

    valid = if value.start_with?("docker://")
      value.match?(/@sha256:[0-9a-f]{64}\z/i)
    else
      value.match?(/@[0-9a-f]{40}\z/i)
    end
    failures << "#{relative}:#{index + 1} action is not SHA-pinned: #{value}" unless valid
  end

  jobs.each do |job_name, job|
    steps = Array(job.fetch("steps", []))
    if sealed_workflows.include?(workflow_name)
      guard = steps.first || {}
      guard_uses = guard.fetch("uses", "")
      guard_with = guard.fetch("with", {})

      if guard_uses.start_with?("GrantBirki/fence@")
        unless guard_with["mode"] == "block"
          failures << "#{relative}:#{job_name} Fence must use mode: block"
        end
        if guard_with.key?("config")
          failures << "#{relative}:#{job_name} Fence must use auditable native inputs, not raw config"
        end
        if guard_with.key?("container_policy") && guard_with["container_policy"] != "disable"
          failures << "#{relative}:#{job_name} Fence must disable container access"
        end
      elsif guard_uses.start_with?("step-security/harden-runner@")
        unless guard_with["egress-policy"] == "block"
          failures << "#{relative}:#{job_name} harden-runner must use egress-policy: block"
        end
        unless guard_with["disable-telemetry"] == true
          failures << "#{relative}:#{job_name} harden-runner must disable telemetry"
        end
        unless guard_with["disable-sudo-and-containers"] == true
          failures << "#{relative}:#{job_name} harden-runner must disable sudo and containers"
        end
      else
        failures << "#{relative}:#{job_name} must run an approved network guard as the first step"
      end
    end

    steps.each do |step|
      uses = step.fetch("uses", "")
      with = step.fetch("with", {})
      if uses.start_with?("actions/checkout@") && with["persist-credentials"] != false
        failures << "#{relative}:#{job_name} checkout must set persist-credentials: false"
      end

      next unless uses.start_with?("ruby/setup-ruby@")

      failures << "#{relative}:#{job_name} ruby/setup-ruby must set bundler: none" unless with["bundler"] == "none"
      failures << "#{relative}:#{job_name} ruby/setup-ruby must set bundler-cache: false" unless with["bundler-cache"] == false
    end
  end
rescue Psych::Exception => e
  failures << "#{relative}: invalid YAML: #{e.message}"
end

unless failures.empty?
  warn failures.join("\n")
  exit 1
end
RUBY
}

validate_bundler_supply_chain
validate_ci_workflow_security

echo -e "\n🧪 ${BLUE}Running tests: $(date "+%H:%M:%S")${OFF}\n"

bundle exec rspec spec

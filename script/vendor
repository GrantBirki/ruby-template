#! /usr/bin/env ruby
# frozen_string_literal: true

require "cgi"
require "json"
require "net/http"
require "time"
require "uri"
require "yaml"

ROOT = File.expand_path("..", __dir__)
DEPENDABOT_PATH = File.join(ROOT, ".github/dependabot.yml")
LOCKFILE_PATH = File.join(ROOT, "Gemfile.lock")
LOCK_COMMAND = ["bundle", "lock", "--add-checksums"].freeze
CACHE_COMMAND = ["bundle", "cache", "--all", "--all-platforms", "--no-install"].freeze

ENV["RBENV_VERSION"] ||= File.read(File.join(ROOT, ".ruby-version")).strip
rbenv_shims = File.join(Dir.home, ".rbenv/shims")
ENV["PATH"] = "#{rbenv_shims}:#{ENV.fetch('PATH')}" if Dir.exist?(rbenv_shims)

module RubyTemplate
  LockedGem = Struct.new(:name, :version, keyword_init: true)

  class VendorError < StandardError; end
  class ReleaseCooldownError < VendorError; end

  class DependabotCooldownPolicy
    attr_reader :days, :source_path

    def self.load(path)
      data = YAML.safe_load(File.read(path), permitted_classes: [], permitted_symbols: [], aliases: false)
      updates = Array(data.fetch("updates"))
      update = updates.find { |entry| entry["package-ecosystem"] == "bundler" && entry["directory"] == "/" } ||
               updates.find { |entry| entry["package-ecosystem"] == "bundler" }
      raise VendorError, "dependabot config has no bundler update entry" unless update

      days = update.dig("cooldown", "default-days")
      unless days.is_a?(Integer) && days.positive?
        raise VendorError, "dependabot bundler cooldown.default-days must be a positive integer"
      end

      new(days: days, source_path: path)
    rescue Errno::ENOENT
      raise VendorError, "dependabot config not found: #{path}"
    rescue KeyError
      raise VendorError, "dependabot config is missing required updates list"
    rescue Psych::Exception => e
      raise VendorError, "dependabot config is invalid YAML: #{e.message}"
    end

    def initialize(days:, source_path:)
      @days = days
      @source_path = source_path
    end
  end

  class LockfileSpecs
    def self.parse(text)
      specs = []
      in_gem_section = false
      in_specs = false

      text.each_line do |line|
        if line == "GEM\n"
          in_gem_section = true
          next
        end

        if in_gem_section && line == "  specs:\n"
          in_specs = true
          next
        end

        if in_specs
          break unless line.start_with?("    ")

          match = line.match(/\A    (?<name>\S+) \((?<version>[^)]+)\)/)
          specs << LockedGem.new(name: match[:name], version: match[:version]) if match
        elsif line.match?(/\A[A-Z]/)
          in_gem_section = false
        end
      end

      specs.uniq.sort_by { |spec| [spec.name, spec.version] }
    end
  end

  class RubyGemsClient
    USER_AGENT = "GrantBirki/ruby-template script/vendor"

    def versions(name)
      uri = URI("https://rubygems.org/api/v1/versions/#{CGI.escape(name)}.json")
      response_body = Net::HTTP.start(uri.host, uri.port, use_ssl: true, open_timeout: 10, read_timeout: 10) do |http|
        request = Net::HTTP::Get.new(uri)
        request["User-Agent"] = USER_AGENT
        response = http.request(request)
        code = response.code.to_i
        raise VendorError, "RubyGems metadata request failed for #{uri}: HTTP #{response.code}" unless code.between?(200, 299)

        response.body.to_s
      end

      data = JSON.parse(response_body)
      raise VendorError, "RubyGems metadata for #{name} was not a JSON array" unless data.is_a?(Array)

      data
    rescue JSON::ParserError => e
      raise VendorError, "RubyGems metadata for #{name} was invalid JSON: #{e.message}"
    end
  end

  class RubyGemsCooldown
    SECONDS_PER_DAY = 86_400

    def initialize(policy:, client:, clock:)
      @policy = policy
      @client = client
      @clock = clock
    end

    def validate!(locked_gems)
      raise VendorError, "Gemfile.lock has no RubyGems specs to validate" if locked_gems.empty?

      too_new = []
      locked_gems.each do |locked_gem|
        version = metadata_for(locked_gem)
        created_at = parse_created_at(version.fetch("created_at", nil), locked_gem)
        next unless created_at > cutoff_time

        too_new << [locked_gem, created_at]
      end
      return true if too_new.empty?

      raise ReleaseCooldownError, cooldown_message(too_new)
    end

    private

    def metadata_for(locked_gem)
      metadata = @client.versions(locked_gem.name).find do |version|
        version_number = version.fetch("number", "").to_s
        platform = version.fetch("platform", "ruby").to_s
        [version_number, "#{version_number}-#{platform}"].include?(locked_gem.version)
      end
      return metadata if metadata

      raise VendorError, "RubyGems metadata did not include #{locked_gem.name} #{locked_gem.version}"
    end

    def parse_created_at(value, locked_gem)
      Time.iso8601(value.to_s).utc
    rescue ArgumentError
      raise VendorError, "RubyGems metadata for #{locked_gem.name} #{locked_gem.version} has invalid created_at"
    end

    def cutoff_time
      @clock.call.utc - (@policy.days * SECONDS_PER_DAY)
    end

    def cooldown_message(too_new)
      lines = [
        "RubyGems cooldown rejected versions newer than #{@policy.days} days from #{relative_path(@policy.source_path)}:"
      ]
      too_new.each do |locked_gem, created_at|
        wait_until = created_at + (@policy.days * SECONDS_PER_DAY)
        lines << "- #{locked_gem.name} #{locked_gem.version} was published #{created_at.iso8601}; wait until #{wait_until.iso8601}"
      end
      lines.join("\n")
    end

    def relative_path(path)
      path.delete_prefix("#{ROOT}/")
    end
  end

  class Vendor
    attr_reader :argv

    def initialize(argv:)
      @argv = argv.dup
      @dry_run = false
    end

    def run
      original_lockfile = nil
      parse_args!
      policy = DependabotCooldownPolicy.load(DEPENDABOT_PATH)
      puts "📦 ruby-template vendor"
      puts "ℹ️  This is the intentional networked dependency refresh path." unless dry_run?
      puts "⚠️  Dry run: no commands will be executed." if dry_run?
      puts "🧊 RubyGems cooldown: #{policy.days} days from #{relative_path(policy.source_path)}"

      original_lockfile = read_lockfile unless dry_run?
      run_command(LOCK_COMMAND)
      enforce_cooldown(policy, original_lockfile) unless dry_run?
      run_command(CACHE_COMMAND)
      puts "✅ Vendored Ruby dependencies are refreshed."
      0
    rescue ReleaseCooldownError => e
      restore_lockfile(original_lockfile)
      warn e.message
      warn "Gemfile.lock was restored to its pre-vendor state." if original_lockfile
      1
    rescue VendorError => e
      warn e.message
      1
    end

    private

    def dry_run?
      @dry_run
    end

    def parse_args!
      until argv.empty?
        arg = argv.shift
        case arg
        when "--dry-run", "-n"
          @dry_run = true
        when "--help", "-h"
          puts usage
          exit 0
        else
          warn "Unknown option: #{arg}"
          warn usage
          exit 2
        end
      end
    end

    def usage
      <<~USAGE
        Usage: script/vendor [--dry-run]

        Refresh vendored Ruby gems and Gemfile.lock checksums.
        RubyGems release age is enforced from .github/dependabot.yml.
      USAGE
    end

    def run_command(command)
      puts "→ #{command.join(' ')}"
      return if dry_run?

      ok = system({ "BUNDLE_FROZEN" => "false" }, *command, chdir: ROOT)
      raise VendorError, "command failed: #{command.join(' ')}" unless ok
    end

    def enforce_cooldown(policy, original_lockfile)
      specs = LockfileSpecs.parse(read_lockfile)
      changed_specs = changed_specs(original_lockfile, specs)
      if changed_specs.empty?
        puts "✅ RubyGems cooldown satisfied; no gem versions changed."
        return
      end

      RubyGemsCooldown.new(policy: policy, client: RubyGemsClient.new, clock: Time.method(:now)).validate!(changed_specs)
      puts "✅ RubyGems cooldown satisfied for #{changed_specs.length} changed gem(s)."
    end

    def changed_specs(original_lockfile, specs)
      original_versions = LockfileSpecs.parse(original_lockfile).to_h { |spec| [spec.name, spec.version] }
      specs.reject { |spec| original_versions[spec.name] == spec.version }
    end

    def read_lockfile
      File.read(LOCKFILE_PATH)
    rescue Errno::ENOENT
      raise VendorError, "Gemfile.lock not found: #{LOCKFILE_PATH}"
    end

    def restore_lockfile(text)
      File.write(LOCKFILE_PATH, text) if text
    end

    def relative_path(path)
      path.delete_prefix("#{ROOT}/")
    end
  end
end

exit RubyTemplate::Vendor.new(argv: ARGV).run
